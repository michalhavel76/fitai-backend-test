// ============================================
// 🌍 FitAI 5.0 – Global Scientific Food Database
// ✅ Railway-ready schema (bez shadow DB)
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// 🥗 Main Table – foods (legacy)
// ============================================
model foods {
  id                  Int              @id @default(autoincrement())
  name_en             String?          @unique(map: "unique_name_en")
  name_cz             String?
  category            String?
  origin              String?
  kcal                Float?
  protein             Float?
  carbs               Float?
  fat                 Float?
  fiber               Float?
  sugar               Float?
  sodium              Float?
  vitamin_a           Float?
  vitamin_c           Float?
  calcium             Float?
  iron                Float?
  source              String?
  image_url           String?
  lang                Json?
  created_at          DateTime?        @default(now())
  accuracy_score      Float?           @default(0.0)
  alcohol             Float?
  biotin_b7           Float?
  caffeine            Float?
  cholesterol         Float?
  choline             Float?
  chromium            Float?
  composition         Json?
  copper              Float?
  dish_name           String?
  folate_b9           Float?
  iodine              Float?
  is_global           Boolean?         @default(false)
  magnesium           Float?
  manganese           Float?
  molybdenum          Float?
  monounsaturated_fat Float?
  niacin_b3           Float?
  omega_3             Float?
  omega_6             Float?
  pantothenic_b5      Float?
  phosphorus          Float?
  polyunsaturated_fat Float?
  potassium           Float?
  region              String?          @default("global")
  riboflavin_b2       Float?
  selenium            Float?
  thiamin_b1          Float?
  trans_fat           Float?
  vitamin_b12         Float?
  vitamin_b6          Float?
  vitamin_d           Float?
  vitamin_e           Float?
  vitamin_k           Float?
  water               Float?
  zinc                Float?
  updated_at          DateTime?        @default(now()) @db.Timestamp(6)

  audit_logs          FoodAuditLog[]
}

// ============================================
// 🌎 Global Table – foods_universal
// ============================================
model foods_universal {
  id                   Int       @id @default(autoincrement())
  name_en              String
  name_cz              String?
  name_de              String?
  name_fr              String?
  name_es              String?
  name_it              String?
  category             String?
  source               String?
  country_origin       String?
  image_url            String?
  scientific_accuracy  Float     @default(0)
  updated_at           DateTime  @default(now())

  // 42 standardized nutrient columns
  kcal                 Float?
  protein              Float?
  fat                  Float?
  carbs                Float?
  fiber                Float?
  sugar                Float?
  sodium               Float?
  calcium              Float?
  iron                 Float?
  magnesium            Float?
  phosphorus           Float?
  potassium            Float?
  zinc                 Float?
  copper               Float?
  manganese            Float?
  selenium             Float?
  vitamin_a            Float?
  vitamin_b1           Float?
  vitamin_b2           Float?
  vitamin_b3           Float?
  vitamin_b5           Float?
  vitamin_b6           Float?
  vitamin_b7           Float?
  vitamin_b9           Float?
  vitamin_b12          Float?
  vitamin_c            Float?
  vitamin_d            Float?
  vitamin_e            Float?
  vitamin_k            Float?
  cholesterol          Float?
  saturated_fat        Float?
  monounsaturated_fat  Float?
  polyunsaturated_fat  Float?
  omega_3              Float?
  omega_6              Float?
  trans_fat            Float?
  water                Float?
  caffeine             Float?
  alcohol              Float?
  ash                  Float?
  pufa_ratio           Float?
  glycemic_index       Float?
}

// ============================================
// 📊 Global Reference Data – FitAI_DataHub
// ============================================
model FitAI_DataHub {
  id             Int       @id @default(autoincrement())
  nutrient_key   String    @unique
  avg_value      Float
  region         String?   @default("global")
  samples_count  Int?      @default(0)
  accuracy_score Float?    @default(0.85)
  created_at     DateTime? @default(now()) @db.Timestamp(6)
  updated_at     DateTime? @default(now()) @updatedAt @db.Timestamp(6)
}

// ============================================
// ⚖️ Legal Trace – FoodAuditLog
// ============================================
model FoodAuditLog {
  id                Int       @id @default(autoincrement())
  food_id           Int
  changed_fields    Json
  source_chain      Json
  reliability_score Float
  timestamp         DateTime  @default(now())

  food              foods     @relation(fields: [food_id], references: [id], onDelete: Cascade)
}
